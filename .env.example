# Local development — copy to .env: cp .env.example .env
# Required: set SECRET_KEY to any non-empty string for local use.
# Production / CDK variables: see infrastructure/.env.example

SECRET_KEY=
DEBUG=True

POSTGRES_DB=kaiznbonsai_db
POSTGRES_USER=kaiznbonsai_user
POSTGRES_PASSWORD=password
POSTGRES_HOST=db
POSTGRES_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:3000

# Comma-separated Host header allowlist (Django ALLOWED_HOSTS)
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Demo account — used by: python manage.py generate_seed_data
DEMO_USER_PASSWORD=Password123!

# AI chat assistant
# Optional: if unset, the /api/v1/assistant/chat/ endpoint returns 503 but the
# rest of the server starts normally.
ANTHROPIC_API_KEY=
