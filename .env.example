# Local development — copy to .env: cp .env.example .env
# Required: set SECRET_KEY to any non-empty string for local use.

SECRET_KEY=
DEBUG=True

POSTGRES_DB=kaiznbonsai_db
POSTGRES_USER=kaiznbonsai_user
POSTGRES_PASSWORD=password
POSTGRES_HOST=db
POSTGRES_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Not used by root docker-compose (documented for reference) ---
#
# VITE_API_URL=http://localhost:8000
#   Production frontend build only (GitHub Actions / manual npm run build).
#   Local dev uses the Vite proxy — no VITE_API_URL needed.
#
# DJANGO_SECRET_KEY=...
# DB_PASSWORD=...
#   CDK deploy only — set in infrastructure/.env when running cdk deploy.
